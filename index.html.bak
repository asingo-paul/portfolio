<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Paul Asingo — Cloud & DevOps Engineer</title>
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --green: #00e676;
            --green-dim: #00c853;
            --green-muted: rgba(0, 230, 118, 0.08);
            --green-border: rgba(0, 230, 118, 0.2);
            --bg: #0d0d0d;
            --bg2: #111111;
            --bg3: #161616;
            --text: #e8e8e8;
            --text-dim: #888;
            --text-muted: #555;
            --mono: 'Courier New', Courier, monospace;
        }

        html { scroll-behavior: smooth; }

        body {
            font-family: 'Segoe UI',sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.7;
            overflow-x: hidden;
        }

        /* SCROLLBAR */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: var(--bg); }
        ::-webkit-scrollbar-thumb { background: var(--green-dim); border-radius: 2px; }

        /* SCROLL PROGRESS */
        #scroll-bar {
            position: fixed; top: 0; left: 0;
            height: 2px; width: 0;
d: var(--green);
            z-index: 9999;
            transition: width 0.1s linear;
        }

        /* NAV */
        nav {
            position: fixed; top: 0; width: 100%;
            background: rgba(13,13,13,0.92);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--green-border);
            padding: 0 6%;
            height: 60px;
            display: flex; align-items: center; justify-content: space-between;
            z-index: 1000;
        }

        .logo {
            font-family: var(--mono);
            font-size: 1rem;
            color: var(--green);
            letter-spacing: 0.05em;
        }
        .logo span { color: var(--text-dim); }

        .nav-links { display: flex; gap: 2rem; list-style: none; }
        .nav-links a {
            color: var(--text-dim);
            text-decoration: none;
            font-size: 0.85rem;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            transition: color 0.2s;
        }
        .nav-links a:hover { color: var(--green); }

        .nav-right { display: flex; align-items: center; gap: 1.2rem; }

        .btn-cv {
            font-family: var(--mono);
            font-size: 0.8rem;
            padding: 0.45rem 1rem;
            border: 1px solid var(--green);
            color: var(--green);
            background: transparent;
            border-radius: 3px;
            text-decoration: none;
            letter-spacing: 0.05em;
            transition: all 0.2s;
        }
        .btn-cv:hover { background: var(--green); color: var(--bg); }

        .burger { display: none; flex-direction: column; gap: 5px; cursor: pointer; }
        .hamburger span { width: 22px; height: 2px; background: var(--green); display: block; transition: all 0.3s; }

        /* HERO */
        .hero {
            min-height: 100vh;
            display: flex; align-items: center;
            padding: 0 6%;
            padding-top: 60px;
        }

        .hero-inner { max-width: 760px; }

        .hero-tag {
            font-family: var(--mono);
            font-size: 0.85rem;
            color: var(--green);
            margin-bottom: 1.2rem;
            letter-spacing: 0.08em;
        }

        .hero h1 {
            font-size: clamp(2.4rem, 5vw, 4rem);
            font-weight: 700;
            line-height: 1.15;
            color: var(--text);
            margin-bottom: 0.6rem;
        }

        .hero h1 em {
            font-style: normal;
            color: var(--green);
        }

        .hero-sub {
            font-size: 1rem;
            color: var(--text-dim);
            max-width: 580px;
            margin-bottom: 2.4rem;
            line-height: 1.8;
        }

        .hero-stats {
            display: flex; gap: 2.5rem;
            margin-bottom: 2.4rem;
            flex-wrap: wrap;
        }

        .stat { border-left: 2px solid var(--green); padding-left: 1rem; }
        .stat-n { font-size: 1.8rem; font-weight: 700; color: var(--green); line-height: 1; }
        .stat-l { font-size: 0em; }

        .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

        .btn-primary {
            padding: 0.75rem 1.8rem;
            background: var(--green);
            color: var(--bg);
            border: none;
            border-radius: 3px;
            font-size: 0.9rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
            cursor: pointer;
        }
        .(-2px); }

        .btn-outline {
            padding: 0.75rem 1.8rem;
            background: transparent;
            color: var(--text);
            border: 1px solid var(--text-muted);
            border-radius: 3px;
            font-size: 0.9rem;
            text-decoration: none;
            transition: all 0.2s;
        }
        .btn-outline:hover { border-color: var(--green); color: var(--green); transform: translateY(-2px); }

        /* SECTIONS */
        section { padd200px; margin: 0 auto; }

        .section-label {
            font-family: var(--mono);
            font-size: 0.78rem;
            color: var(--green);
            letter-spacing: 0.12em;
            text-transform: uppercase;
            margin-bottom: 0.5rem;
        }

        .section-title {
            font-size: clamp(1.6rem, 3vw, 2.2rem);
            font-weight: 700;
            color: var(--text);
            margin-bottom: 3rem;
        }

        .divider {
            width: 40px; height: 2px;
            background: var(--green);
            margin: 0.6rem 0 2.5rem;
        }

        /* ABOUT */
        .about-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: start;
        }

        .about-text p { color: var(--text-dim); margin-bottom: 1rem; font-size: 0.95rem; }

        .about-highlights { display: flex; flex-direction: column; gap: 1rem; }

        .highlight-card {
            background: var(--bg3);
            border: 1px solid var(--green-border);
            border-radius: 6px;
            padding: 1.2rem 1.5rem;
            display: flex; align-items: center; gap: 1.2rem;
        }

        .highlight-val {
            font-size: 1.6rem; font-weight: 700;
            color: var(--green); min-width: 60px;
            font-family: var(--mono);
        }

        .highlight-desc { font-size: 0.85rem; color: var(--text-dim); }

        /* SKILLS */
        .skills-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 1.2rem;
        }

        .skill-card {
            background: var(--bg3);
            border: 1px solid #1e1e1e;
            border-radius: 6px;
            padding: 1.5rem;
            transition: border-color 0.2s, transform 0.2s;
        }
        .skill-card:hover er); transform: translateY(-3px); }

        .skill-card h3 {
            font-size: 0.82rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--green);
            margin-bottom: 1rem;
            font-family: var(--mono);
        }

        .tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }

        .tag {
            font-size: 0.78rem;
            padding: 0.3rem 0.7rem;
            background: var(--green-muted);
         en-border);
            border-radius: 3px;
            color: var(--text-dim);
        }

        /* EXPERIENCE */
        .timeline { position: relative; padding-left: 1.5rem; }
        .timeline::before {
            content: '';
            position: absolute; left: 0; top: 6px; bottom: 0;
            width: 1px; background: var(--green-border);
        }

        .tl-item {
            position: relative;
            padding: 1.8rem 2rem;
            background: var(--bg3);
            border: 1px solid #1e1e;
            border-radius: 6px;
            margin-bottom: 1.5rem;
            margin-left: 1.5rem;
            transition: border-color 0.2s;
        }
        .tl-item:hover { border-color: var(--green-border); }

        .tl-item::before {
            content: '';
            position: absolute;
            left: -2.1rem; top: 1.8rem;
            width: 8px; height: 8px;
            background: var(--green);
            border-radius: 50%;
            box-shadow: 0 0 10px var(--green);
        }

        .tl-header { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.4rem; }

        .tl-title { font-size: 1rem; font-weight: 600; color: var(--text); }
        .tl-company { font-size: 0.85rem; color: var(--green); margin-bottom: 0.3rem; }
        .tl-date { font-family: var(--mono); font-size: 0.78rem; color: var(--text-muted); white-space: nowrap; }

        .tl-desc { font-size: 0.88rem; color: var(--text-dim); margin-bottom: 1rem; }

        .tl-list { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
        .tl-list li {
            font-size: 0.85rem; color: var(--text-dim);
            padding-left: 1.2rem; position: relative;
        }
        .tl-list li::before { content: '›'; position: absolute; left: 0; color: var(--green); }

        /* PROJECTS */
        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 1.2rem;
        }

        .project-card {
            background: var(--bg3);
            border: 1px solid #1e1e1e;
            border-radius: 6px;
            padding: 1.8rem;
            display: flex; flex-direction: column;
            transition: border-color 0.2s, transform 0.2s;
        }
        .project-card:hover { border-color: var(--green-border); transform: translateY(-4px); }

        .project-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.8rem; }

t-size: 1.4rem; }

        .project-links-top { display: flex; gap: 0.8rem; }
        .project-links-top a {
            font-size: 0.78rem; color: var(--text-muted);
            text-decoration: none; transition: color 0.2s;
            font-family: var(--mono);
        }
        .project-links-top a:hover { color: var(--green); }

        .project-card h3 { font-size: 1rem; font-weight: 600; color: var(--text); margin-bottom: 0.5rem; }
 1; margin-bottom: 1.2rem; }

        .project-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
        .project-tag {
            font-size: 0.72rem; font-family: var(--mono);
            color: var(--green); background: var(--green-muted);
            padding: 0.2rem 0.6rem; border-radius: 2px;
        }

        /* CERTIFICATIONS */
        .cert-grid { display: flex; flex-direction: column; gap: 1rem; max-width: 700px; }

        .cert-card {
            background: var(--bg3);
            border: 1px solid #1e1e1e;
            border-left: 3px solid var(--green);
            border-radius: 6px;
            padding: 1.2rem 1.5rem;
            display: flex; align-items: center; gap: 1.2rem;
            transition: border-color 0.2s;
        }
        .cert-card:hover { border-color: var(--green); }

        .cert-badge {
            font-family: var(--mono); font-size: 0.7rem;
            padding: 0.3rem 0.6rem;
            border: 1px solid var(--green);
            color: var(--green); bo 3px;
            white-space: nowrap;
        }

        .cert-info h3 { font-size: 0.95rem; color: var(--text); margin-bottom: 0.2rem; }
        .cert-info span { font-size: 0.8rem; color: var(--text-dim); }
        .cert-pursuing { color: var(--green); font-size: 0.78rem; font-family: var(--mono); }

        /* CONTACT */
        .contact-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            max-width: 700px;
        }

        .contact-card {
            background: var(--bg3);
            border: 1px solid #1e1e1e;
            border-radius: 6px;
            padding: 1.4rem;
            text-decoration: none;
            color: var(--text);
            transition: all 0.2s;
            display: flex; flex-direction: column; gap: 0.4rem;
        }
        .contact-card:hover { border-color: var(--green-border); transform: translateY(-3px); }

        .contact-card-labeer-spacing: 0.1em; color: var(--text-muted); font-family: var(--mono); }
        .contact-card-val { font-size: 0.88rem; color: var(--text-dim); }
        .contact-card:hover .contact-card-val { color: var(--green); }

        /* FOOTER */
        footer {
            border-top: 1px solid #1a1a1a;
            padding: 2rem 6%;
            display: flex; justify-content: space-between; align-items: center;
            flex-wrap: wrap; gap: 1rem;
            color: var(--text-muted); font-size: 0.8rem;
        }

        footer a { color: var(--text-muted); text-decoration: none; transition: color 0.2s; }
        footer a:hover { color: var(--green); }

        /* MOBILE */
        @media (max-width: 768px) {
            .nav-links { display: none; position: absolute; top: 60px; left: 0; width: 100%; background: var(--bg2); flex-direction: column; padding: 1.5rem 6%; gap: 1.2rem; border-bottom: 1px solid var(--green-border); }
            .nav-links.open { display: flex; }
            .hamburger { display: flex; }
            .about-grid { grid-template-columns: 1fr; gap: 2rem; }
            .hero-stats { gap: 1.5rem; }
            footer { flex-direction: column; text-align: center; }
        }
    </style>
</head>

