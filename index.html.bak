<div id="scroll-bar"></div>

<nav>
    <div class="logo"><span>~/</span>paul-asingo</div>
    <ul class="nav-links" id="navLinks">
        <li><a href="#about">About</a></li>
        <li><a href="#skills">Skills</a></li>
        <li><a href="#experience">Experience</a></li>
        <li><a href="#projects">Projects</a></li>
        <li><a href="#contact">Contact</a></li>
    </ul>
    <div class="nav-right">
        <a href="CLOUD-DEVOPS.pdf" download="Paul_Asingo_CV.pdf" class="btn-cv">↓ CV</a>
        <div class="hamburger" id="hamburger">
            <span></span><span></span><span></span>
        </div>
    </div>
</nav>

<!-- HERO -->
<section class="hero" id="home">
    <div class="hero-inner">
        <div class="hero-tag">// cloud & devops engineer</div>
        <h1>Paul <em>Asingo</em></h1>
        <p class="hero-sub">
          target="_blank" style="color:var(--green);text-decoration:none;">cloudora.live</a>.
        </p>
        <div class="hero-stats">
            <div class="stat">
                <div class="stat-n">85%</div>
                <div class="stat-l">Setup Time Reduction</div>
            </div>
            <div class="stat">
                <div class="stat-n">20%</div>
                <div class="stat-l">Cost Optimization</div>
            </div>
            <div class="stat">
                <div cla>8+</div>
                <div class="stat-l">GitHub Projects</div>
            </div>
        </div>
        <div class="hero-actions">
            <a href="#contact" class="btn-primary">Get in touch</a>
            <a href="#projects" class="btn-outline">View projects</a>
